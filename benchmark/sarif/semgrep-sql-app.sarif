{"version":"2.1.0","runs":[{"invocations":[{"executionSuccessful":true,"toolExecutionNotifications":[]}],"results":[{"fingerprints":{"matchBasedId/v1":"requires login"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"targets/sql-app/Dockerfile","uriBaseId":"%SRCROOT%"},"region":{"endColumn":99,"endLine":7,"snippet":{"text":"CMD [\"gunicorn\", \"-w\", \"2\", \"--threads\", \"4\", \"-b\", \"0.0.0.0:8085\", \"--timeout\", \"120\", \"app:app\"]"},"startColumn":1,"startLine":7}}}],"message":{"text":"By not specifying a USER, a program in the container may run as 'root'. This is a security hazard. If an attacker can control a process running as root, they may have control over the container. Ensure that the last USER in a Dockerfile is a USER other than 'root'."},"properties":{},"ruleId":"dockerfile.security.missing-user.missing-user"},{"fingerprints":{"matchBasedId/v1":"requires login"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"targets/sql-app/app.py","uriBaseId":"%SRCROOT%"},"region":{"endColumn":57,"endLine":14,"snippet":{"text":"        m = importlib.import_module(f\"vulns.{mod.name}\")"},"startColumn":13,"startLine":14}}}],"message":{"text":"Untrusted user input in `importlib.import_module()` function allows an attacker to load arbitrary code. Avoid dynamic values in `importlib.import_module()` or use a whitelist to prevent running untrusted code."},"properties":{},"ruleId":"python.lang.security.audit.non-literal-import.non-literal-import"},{"fingerprints":{"matchBasedId/v1":"requires login"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"targets/sql-app/app.py","uriBaseId":"%SRCROOT%"},"region":{"endColumn":39,"endLine":33,"snippet":{"text":"    app.run(host=\"0.0.0.0\", port=8085)"},"startColumn":5,"startLine":33}}}],"message":{"text":"Running flask app with host 0.0.0.0 could expose the server publicly."},"properties":{},"ruleId":"python.flask.security.audit.app-run-param-config.avoid_app_run_with_bad_host"},{"fingerpr