{
  "$schema": "https://json.schemastore.org/aiproj-1.9.json",
  "Version": "1.9",
  "ProjectName": "vuln-jsts-web-default",
  "ProgrammingLanguages": [
    "JavaScript"
  ],
  "ScanModules": [
    "StaticCodeAnalysis"
  ],
  "ApplyAllPMRules": false,
  "UseSecurityPolicies": false,
  "SkipGitIgnoreFiles": false,
  "JavaScriptSettings": {
    "UsePublicAnalysisMethod": true,
    "DownloadDependencies": false,
    "UseTaintAnalysis": true,
    "UseJsaAnalysis": true,
    "CustomParameters": "",
    "DslRulesRelativePath": ""
  },
  "PmTaintSettings": {
    "UsePublicAnalysisMethod": true,
    "CustomParameters": "",
    "PMGroups": []
  },
  "PygrepSettings": {
    "CustomParameters": ""
  }
}